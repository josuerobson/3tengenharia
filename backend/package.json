{
  "name": "3t-backend",
  "version": "1.0.0",
  "description": "Sistema Integrado de Gestão Operacional 3T — API Backend",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/server.js",
    "db:generate": "prisma generate --schema=../prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema=../prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=../prisma/schema.prisma",
    "db:studio": "prisma studio --schema=../prisma/schema.prisma",
    "db:seed": "tsx src/lib/seed.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
