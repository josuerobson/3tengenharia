# Variáveis de ambiente — Backend 3T
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA versione o arquivo .env no Git.

# ──────────────────────────────────────────────
# BANCO DE DADOS
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/3t_db?schema=public"

# ──────────────────────────────────────────────
# SERVIDOR
# ──────────────────────────────────────────────
PORT=3333
HOST=0.0.0.0
NODE_ENV=development

# ──────────────────────────────────────────────
# JWT
# ──────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=SUBSTITUA_POR_UMA_CHAVE_SEGURA_DE_64_BYTES_HEX
JWT_EXPIRES_IN=8h

# ──────────────────────────────────────────────
# CORS — separe múltiplas origens com vírgula
# ──────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ──────────────────────────────────────────────
# BCRYPT
# ──────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
